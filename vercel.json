{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/controllers/**,backend/routes/**,backend/utils/**,backend/prisma/**,backend/server.js"
    }
  }
}